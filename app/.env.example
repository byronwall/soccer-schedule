# Required for AI SDK calls to OpenAI.
OPENAI_API_KEY=your_openai_api_key_here

# App-level model defaults.
OPENAI_MODEL=gpt-5-mini
OPENAI_HEAVY_MODEL=gpt-5.4

# App URL used for Stripe redirects and magic links. Coolify supplies
# SERVICE_URL_APP automatically; APP_BASE_URL remains a portable fallback.
SERVICE_URL_APP=
APP_BASE_URL=http://localhost:3000
PRODUCT_NAME=Coach Companion

# Master sign-in. The master user can create additional user/password pairs in
# the app. Use a unique random password of at least 12 characters.
MASTER_USERNAME=admin
MASTER_DISPLAY_NAME=Administrator
MASTER_PASSWORD=replace-with-a-long-random-master-password
AUTH_CREDENTIAL_VERSION=1

# Persistent server data directory. Docker Compose mounts a named volume here.
APP_DATA_DIR=app/data

# Inherited file-backed auth/admin integrations.
EMAIL_DELIVERY=console
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM="Coach Companion <support@example.com>"
SUPER_USER_EMAIL=owner@example.com

# Inherited Stripe credit-pack billing.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_CREDIT_PACK=price_your_credit_pack_price_here
CREDIT_PACK_CREDITS=10
CREDIT_PACK_AMOUNT_CENTS=1000
CREDIT_PACK_CURRENCY=usd
